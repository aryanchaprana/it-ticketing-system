# Flask Core
FLASK_ENV=development
SECRET_KEY=your-very-long-random-secret-key-here

# PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/nash_energy_tickets

# Flask-Mail (example uses Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=it-support@nashenergy.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=Nash Energy IT Support <it-support@nashenergy.com>

# File Uploads
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=5242880

# Seeded Admin Account — change immediately after first login
ADMIN_EMAIL=admin@nashenergy.com
ADMIN_PASSWORD=Admin@1234!
